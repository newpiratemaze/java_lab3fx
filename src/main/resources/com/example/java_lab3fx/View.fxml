<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="600.0" prefWidth="750.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.java_lab3fx.Controller">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <ImageView fx:id="imageView" fitHeight="447.0" fitWidth="701.0" pickOnBounds="true" preserveRatio="true" />
   <HBox alignment="CENTER" prefHeight="39.0" prefWidth="449.0">
      <children>
         <Button fx:id="firstImgBtn" mnemonicParsing="false" onAction="#firstPic" text="&lt;&lt;" />
         <Button fx:id="prevImgBtn" mnemonicParsing="false" onAction="#prevPic" text="&lt;" />
         <TextField fx:id="indexField" editable="false" prefHeight="25.0" prefWidth="51.0" />
         <Button fx:id="nextImgBtn" mnemonicParsing="false" onAction="#nextPic" text="&gt;" />
         <Button fx:id="lastImgBtn" mnemonicParsing="false" onAction="#lastPic" text="&gt;&gt;" />
      </children>
   </HBox>
   <Button fx:id="loadBtn" mnemonicParsing="false" onAction="#loadPhotos" prefHeight="25.0" prefWidth="168.0" text="Загрузить фотографии" />
</VBox>
